# ===== AI Providers (Phase A) =====
# 默认 provider(可选: minimax / claude / openai)
DEFAULT_AI_PROVIDER=minimax

# MiniMax — 在 https://platform.minimaxi.com 获取
MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# OpenAI 兼容(支持 OpenAI 官方 / Ollama / vLLM / Together / Groq 等)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Claude (Anthropic) — 在 https://console.anthropic.com 获取
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-haiku-4-5

# ===== 公众号(WeChat MP) — 在 https://mp.weixin.qq.com 开发者后台拿 =====
# 缺这两个的话,公众号 adapter 会报"未配置"且不调真 API
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_API_BASE=https://api.weixin.qq.com

# ===== NotebookLM — 参考 qiaomu-anything-to-notebooklm =====
# 用法: 先 `pipx install "notebooklm-py[browser]"`, 然后 `notebooklm login` 引导浏览器登录
# 后端只调 CLI 不会主动登录;未登录时 Sources 页提示用户跑 `notebooklm login`
NOTEBOOKLM_BIN=notebooklm

# NotebookLM 是 Google 服务(国外站);网络受限时设代理
# 例: NOTEBOOKLM_PROXY=http://127.0.0.1:7890
# 留空 = 不设代理(走系统默认)
NOTEBOOKLM_PROXY=

# 应用配置
APP_NAME=Self-Media Platform
DEBUG=true

# 数据库 (P1)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/selfmedia

# 对象存储 (P1)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=selfmedia

# Redis (P1)
REDIS_URL=redis://localhost:6379/0

# JWT (P1)
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
