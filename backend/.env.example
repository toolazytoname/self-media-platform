# MiniMax API 配置 - 在 https://platform.minimaxi.com 获取
MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# 应用配置
APP_NAME=Self-Media Platform
DEBUG=true

# 数据库 (P1)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/selfmedia

# 对象存储 (P1)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=selfmedia

# Redis (P1)
REDIS_URL=redis://localhost:6379/0

# JWT (P1)
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
